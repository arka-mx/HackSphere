data/plots/
*.png

# Merged/processed dataset (regenerated from raw sources)
data/dataset.csv

# CatBoost runtime training logs
catboost_info/

# Raw Kaggle datasets (large CSVs/XLSXs — download via Kaggle API)
data/raw/

# Smoke / debug test scripts
test_backend.py
